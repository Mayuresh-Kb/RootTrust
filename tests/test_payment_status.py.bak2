"""
Unit tests for payment status retrieval endpoint.
Tests GET /payments/{transactionId} endpoint functionality.
"""
import json
import pytest
from datetime import datetime, timedelta
from unittest.mock import patch, MagicMock
import sys
import os

# Add backend paths to sys.path
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'backend'))
sys.path.insert(0, os.path.join(os.path.dirname(__file__), '..', 'backend', 'shared'))

# Import after path setup
from shared.constants import UserRole, PaymentStatus, PaymentGateway, PaymentMethod, OrderStatus
from shared.auth import generate_jwt_token

# Import the handler module
from payments import get_payment_status


@pytest.fixture
def mock_env(monkeypatch):
    """Set up mock environment variables."""
    monkeypatch.setenv('DYNAMODB_TABLE_NAME', 'RootTrustData-test')
    monkeypatch.setenv('JWT_SECRET_KEY', 'test-secret-key-12345')


