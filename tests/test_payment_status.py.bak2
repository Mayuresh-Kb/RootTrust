                return None
            
            mock_get_item.side_effect = get_item_side_effect
            
            response = get_payment_status.handler(api_gateway_event, None)
            
            assert response['statusCode'] == 403
            body = json.loads(response['body'])
            assert body['error']['code'] == 'FORBIDDEN'
    
    def test_database_error(self, api_gateway_event):
        """Test handling of database errors."""
        with patch('payments.get_payment_status.get_user_from_token') as mock_auth, \
             patch('payments.get_payment_status.get_item') as mock_get_item:
            
            mock_auth.return_value = {
                'userId': 'consumer123',
                'role': UserRole.CONSUMER.value,
                'email': 'consumer@test.com'
            }
            
            # Simulate database error
            mock_get_item.side_effect = Exception('Database connection failed')
            
            response = get_payment_status.handler(api_gateway_event, None)
            
            assert response['statusCode'] == 503
            body = json.loads(response['body'])
            assert body['error']['code'] == 'SERVICE_UNAVAILABLE'
    
    def test_transaction_without_order(self, api_gateway_event, mock_transaction):
        """Test transaction that doesn't have an associated order."""
        # Remove orderId from transaction
        mock_transaction_no_order = mock_transaction.copy()
        mock_transaction_no_order['orderId'] = None
        
        with patch('payments.get_payment_status.get_user_from_token') as mock_auth, \
             patch('payments.get_payment_status.get_item') as mock_get_item:
            
            mock_auth.return_value = {
                'userId': 'consumer123',
                'role': UserRole.CONSUMER.value,
                'email': 'consumer@test.com'
            }
            
            mock_get_item.return_value = mock_transaction_no_order
            
            response = get_payment_status.handler(api_gateway_event, None)
            
            # Should still return transaction details even without order
            assert response['statusCode'] == 200
            body = json.loads(response['body'])
            assert body['transactionId'] == 'txn_test123'
            assert body['orderId'] is None
    
    def test_razorpay_transaction(self, api_gateway_event, mock_transaction, mock_order):
        """Test retrieval of Razorpay transaction."""
        # Modify to Razorpay gateway
        mock_transaction['paymentGateway'] = PaymentGateway.RAZORPAY.value
        mock_transaction['paymentMethod'] = PaymentMethod.UPI.value
        
        with patch('payments.get_payment_status.get_user_from_token') as mock_auth, \
             patch('payments.get_payment_status.get_item') as mock_get_item:
            
            mock_auth.return_value = {
                'userId': 'consumer123',
                'role': UserRole.CONSUMER.value,
                'email': 'consumer@test.com'
            }
            
            def get_item_side_effect(pk, sk):
                if pk == 'TRANSACTION#txn_test123':
                    return mock_transaction
                elif pk == 'ORDER#order_test456':
                    return mock_order
                return None
            
            mock_get_item.side_effect = get_item_side_effect
            
            response = get_payment_status.handler(api_gateway_event, None)
            
            assert response['statusCode'] == 200
            body = json.loads(response['body'])
            assert body['paymentGateway'] == PaymentGateway.RAZORPAY.value
            assert body['paymentMethod'] == PaymentMethod.UPI.value
    
    def test_cors_headers_present(self, api_gateway_event, mock_transaction, mock_order):
        """Test that CORS headers are present in response."""
        with patch('payments.get_payment_status.get_user_from_token') as mock_auth, \
             patch('payments.get_payment_status.get_item') as mock_get_item:
            
            mock_auth.return_value = {
                'userId': 'consumer123',
                'role': UserRole.CONSUMER.value,
                'email': 'consumer@test.com'
            }
            
            def get_item_side_effect(pk, sk):
                if pk == 'TRANSACTION#txn_test123':
                    return mock_transaction
                elif pk == 'ORDER#order_test456':
                    return mock_order
                return None
            
            mock_get_item.side_effect = get_item_side_effect
            
            response = get_payment_status.handler(api_gateway_event, None)
            
            assert 'Access-Control-Allow-Origin' in response['headers']
            assert response['headers']['Access-Control-Allow-Origin'] == '*'
    
    def test_unexpected_error_handling(self, api_gateway_event):
        """Test handling of unexpected errors."""
        with patch('payments.get_payment_status.get_user_from_token') as mock_auth:
            # Cause an unexpected error
            mock_auth.side_effect = RuntimeError('Unexpected error')
            
            response = get_payment_status.handler(api_gateway_event, None)
            
            assert response['statusCode'] == 500
            body = json.loads(response['body'])
            assert body['error']['code'] == 'INTERNAL_ERROR'


if __name__ == '__main__':
    pytest.main([__file__, '-v'])
