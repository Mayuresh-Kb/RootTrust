def mock_transaction():
    """Mock transaction data."""
    return {
        'PK': 'TRANSACTION#txn_test123',
        'SK': 'METADATA',
        'EntityType': 'Transaction',
        'transactionId': 'txn_test123',
        'orderId': 'order_test456',
        'amount': 1500.00,
        'currency': 'INR',
        'status': PaymentStatus.COMPLETED.value,
        'paymentMethod': PaymentMethod.CARD.value,
        'paymentGateway': PaymentGateway.STRIPE.value,
        'createdAt': '2024-01-15T10:00:00Z',
        'completedAt': '2024-01-15T10:05:00Z',
        'GSI2PK': 'ORDER#order_test456',
        'GSI2SK': 'TRANSACTION#2024-01-15T10:00:00Z'
    }


@pytest.fixture
def mock_order():
    """Mock order data."""
    return {
        'PK': 'ORDER#order_test456',
        'SK': 'METADATA',
        'EntityType': 'Order',
        'orderId': 'order_test456',
        'consumerId': 'consumer123',
        'farmerId': 'farmer456',
